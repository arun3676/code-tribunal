# Copy to .env at the repo root for docker compose local development.
# See DEPLOYMENT.md for production (Railway + Vercel).

# --- Reasoning layer: LLM providers (apps/api) ---
# Groq + Cerebras power the Tribunal agents and the Solo/Council samples.
# Bring your own keys (free tiers available); the fallback chain skips any that are unset.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
TRIBUNAL_LLM_PROVIDERS=groq,cerebras,gemini

# Optional per-provider model overrides
# (defaults: llama-3.3-70b-versatile / zai-glm-4.7 / gemini-3.5-flash)
# GROQ_MODEL=
# CEREBRAS_MODEL=
# GEMINI_MODEL=

# Optional legacy sample providers (only used if a key is present)
DEEPSEEK_API_KEY=
MERCURY_API_KEY=
KIMI_API_KEY=

# --- Frontend (apps/web via docker-compose) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- API CORS ---
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Coordination layer ---
# Which coordination backend runs the room. "band" today; swappable later.
COORDINATION_BACKEND=band

# --- Tribunal / Band ---
# Set BAND_ENABLED=true + BAND_API_KEY for live Band room mirroring.
BAND_ENABLED=false
BAND_STRICT=false
BAND_API_KEY=
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_CLERK_ID=
BAND_ADVOCATE_ID=
BAND_SURVEYOR_ID=
BAND_GHOST_ID=
BAND_DRIFT_ID=
BAND_WARDEN_ID=
BAND_ARBITER_ID=

# Optional per-agent keys (messages appear from each agent's identity)
BAND_CLERK_API_KEY=
BAND_ADVOCATE_API_KEY=
BAND_SURVEYOR_API_KEY=
BAND_GHOST_API_KEY=
BAND_DRIFT_API_KEY=
BAND_WARDEN_API_KEY=
BAND_ARBITER_API_KEY=

# Waitlist invitations (landing page "coming soon" signups)
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=
