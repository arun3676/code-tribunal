# --- Reasoning layer: LLM providers ---
# Groq + Cerebras power the Tribunal agents and the Solo/Council samples.
# Bring your own keys (free tiers available); the fallback chain skips any unset provider.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
# Fallback chain order (first available provider wins per call)
TRIBUNAL_LLM_PROVIDERS=groq,cerebras,gemini

# Optional legacy sample providers (only used if a key is present)
DEEPSEEK_API_KEY=
MERCURY_API_KEY=
Kimi_API_KEY=

# Comma-separated list of exact frontend origins.
# Production example:
# ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional regex for preview deployments.
# Vercel preview example:
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
ALLOWED_ORIGIN_REGEX=

# Railway runtime port. Railway injects PORT automatically in production.
PORT=8000

# ===== Coordination layer =====
# Which coordination backend runs the room. "band" today; swappable later.
COORDINATION_BACKEND=band

# ===== Tribunal (Band coordination) =====
# When BAND_ENABLED=true and BAND_API_KEY is set, the runner mirrors each trial
# into a real Band room (messages, events, WARDEN recruitment). Otherwise the
# trial still streams locally in "demo" mode.
BAND_ENABLED=false
BAND_STRICT=false
BAND_API_KEY=
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_CLERK_ID=
BAND_ADVOCATE_ID=
BAND_SURVEYOR_ID=
BAND_GHOST_ID=
BAND_DRIFT_ID=
BAND_WARDEN_ID=
BAND_ARBITER_ID=

# Optional per-agent keys (messages appear from each agent's identity)
BAND_CLERK_API_KEY=
BAND_ADVOCATE_API_KEY=
BAND_SURVEYOR_API_KEY=
BAND_GHOST_API_KEY=
BAND_DRIFT_API_KEY=
BAND_WARDEN_API_KEY=
BAND_ARBITER_API_KEY=
