# Google Gemini API key for gemini-2.5-flash
GEMINI_API_KEY=

# DeepSeek API key for deepseek-chat
DEEPSEEK_API_KEY=

# Mercury API key for mercury-coder-small
MERCURY_API_KEY=

# Kimi / Moonshot API key for moonshot-v1-8k
Kimi_API_KEY=

# Comma-separated list of exact frontend origins.
# Production example:
# ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional regex for preview deployments.
# Vercel preview example:
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
ALLOWED_ORIGIN_REGEX=

# Railway runtime port. Railway injects PORT automatically in production.
PORT=8000

# ===== Tribunal (Band of Agents) =====
# When BAND_ENABLED=true and BAND_API_KEY is set, the runner mirrors each trial
# into a real Band room (messages, events, WARDEN recruitment). Otherwise the
# trial still streams locally in "demo" mode. Promo: BANDHACK26.
BAND_ENABLED=false
BAND_STRICT=false
BAND_API_KEY=
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_CLERK_ID=
BAND_ADVOCATE_ID=
BAND_SURVEYOR_ID=
BAND_GHOST_ID=
BAND_DRIFT_ID=
BAND_WARDEN_ID=
BAND_ARBITER_ID=

# Optional per-agent keys (messages appear from each agent's identity)
BAND_CLERK_API_KEY=
BAND_ADVOCATE_API_KEY=
BAND_SURVEYOR_API_KEY=
BAND_GHOST_API_KEY=
BAND_DRIFT_API_KEY=
BAND_WARDEN_API_KEY=
BAND_ARBITER_API_KEY=

# Partner providers for agent reasoning (optional — deterministic fallback if absent)
AIMLAPI_API_KEY=
FEATHERLESS_API_KEY=    # Promo: BOA26
